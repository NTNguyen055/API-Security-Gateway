# FIX 1: Thêm biến quản lý thời gian sống của Session (Đồng bộ với JWT)
# 3600 giây = 1 giờ
SESSION_TTL=3600

# =============================================================================
# DJANGO SECURITY FLAGS
# (settings.py đọc trực tiếp — giữ để tham khảo, logic nằm trong settings.py)
# =============================================================================
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SECURE_HSTS_SECONDS=31536000

# =============================================================================
# DATABASE (AWS RDS MySQL)
# =============================================================================
DB_NAME=docaspythondb
DB_USER=admin
DB_PASSWORD=Banhmi4o
DB_HOST=api-gateway-sec-db.c9souy6mmpqf.ap-northeast-1.rds.amazonaws.com
DB_PORT=3306

# =============================================================================
# REDIS
# Django dùng db=1, Lua (OpenResty) dùng db=0 — không conflict
# =============================================================================
REDIS_URL=redis://redis:6379/1

# =============================================================================
# AWS S3 — Static & Media Storage
# =============================================================================
USE_S3=True
AWS_STORAGE_BUCKET_NAME=docapp-assets-apigateway-security
AWS_S3_REGION_NAME=ap-northeast-1

# =============================================================================
# GATEWAY — RATE LIMIT (Local leaky bucket per worker)
# RATE_LIMIT_RPS  : requests/s được phép qua không delay
# RATE_LIMIT_BURST: burst tối đa trước khi reject
# =============================================================================
RATE_LIMIT_RPS=10
RATE_LIMIT_BURST=20

# =============================================================================
# GATEWAY — AUTO BLACKLIST
# AUTO_BL_THRESHOLD : số lần vượt rate limit trong window → tự động blacklist
# AUTO_BL_WINDOW    : cửa sổ đếm (giây)
# AUTO_BL_DURATION  : thời gian blacklist (giây) — mặc định 1 giờ
# =============================================================================
AUTO_BL_THRESHOLD=5
AUTO_BL_WINDOW=60
AUTO_BL_DURATION=3600

# =============================================================================
# GATEWAY — REDIS RATE LIMIT (Distributed counter, sliding window)
# REDIS_RATE_LIMIT : số request tối đa trong window
# REDIS_RL_WINDOW  : độ rộng cửa sổ (giây)
# =============================================================================
REDIS_RATE_LIMIT=120
REDIS_RL_WINDOW=60

# =============================================================================
# GATEWAY — RISK ENGINE
# RISK_LIMIT_THRESHOLD : risk score >= giá trị này → HTTP 429
# RISK_BLOCK_THRESHOLD : risk score >= giá trị này → HTTP 403
# =============================================================================
RISK_LIMIT_THRESHOLD=50
RISK_BLOCK_THRESHOLD=80
