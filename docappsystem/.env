SECRET_KEY=)4^$7i=!582bqv0t%s#*b@sv*$*r5vc2%u7-fduhi041&g&$%y
JWT_SECRET_KEY=7ecfec933ef2a76d85ff388fd137bf028bccd045019da6f4e40ab3bc7c324f57

DEBUG=False
